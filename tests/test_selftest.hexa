#!hexa strict
// tests/test_selftest.hexa — 3-pillar selftest harness for hexa-cosmos
//
// Pass criterion: __HEXA_COSMOS_SELFTEST__ PASS sentinel present.
// Cost: $0 (orchestrates the placeholder CLI router; pure markdown spec check).

fn main() {
    let root = env("HEXA_COSMOS_ROOT")
    let mut p = "cli/hexa-cosmos.hexa"
    if root.len() > 0 { p = root + "/cli/hexa-cosmos.hexa" }

    let raw = exec("hexa run " + p + " selftest 2>&1")
    if raw.contains("__HEXA_COSMOS_SELFTEST__ PASS") {
        println("test_selftest: PASS")
        return
    }
    println("test_selftest: FAIL")
    println(raw.trim())
    exit(1)
}
